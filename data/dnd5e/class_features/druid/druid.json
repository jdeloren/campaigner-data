[
  {
    "id": "feat:druidic",
    "class": "class:druid",
    "level": 1,
    "name": "Druidic",
    "description": "You know Druidic, the secret language of druids. You can speak the language and use it to leave hidden messages. You and others who know this language automatically spot such a message. Others spot the message's presence with a successful DC 15 Wisdom (Perception) check but can't decipher it without magic.",
    "mechanics": [
      {
        "type": "proficiency",
        "category": "language",
        "proficiencies": ["Druidic"]
      }
    ],
    "source": "phb",
    "ruleset": "dnd5e"
  },
  {
    "id": "feat:druid-circle",
    "class": "class:druid",
    "level": 2,
    "name": "Druid Circle",
    "description": "At 2nd level, you choose to identify with a circle of druids. Your choice grants you features at 2nd level and again at 6th, 10th, and 14th level.",
    "mechanics": [
      {
        "type": "choice",
        "choice_type": "subclass"
      }
    ],
    "source": "phb",
    "ruleset": "dnd5e"
  },
  {
    "id": "feat:wild-shape",
    "class": "class:druid",
    "level": 2,
    "name": "Wild Shape",
    "description": "Starting at 2nd level, you can use your action to magically assume the shape of a beast that you have seen before. You can use this feature twice. You regain expended uses when you finish a short or long rest.\n\nYour druid level determines the beasts you can transform into. At 2nd level, for example, you can transform into any beast that has a challenge rating of 1/4 or lower that doesn't have a flying or swimming speed.\n\nYou can stay in a beast shape for a number of hours equal to half your druid level (rounded down). You then revert to your normal form unless you expend another use of this feature. You can revert to your normal form earlier by using a bonus action on your turn. You automatically revert if you fall unconscious, drop to 0 hit points, or die.",
    "mechanics": [
      {
        "type": "resource",
        "id": "wild_shape",
        "name": "Wild Shape",
        "count": {
          "type": "static",
          "value": 2
        },
        "recharge": "short_rest"
      },
      {
        "type": "action",
        "cost": [
          {
            "resource": "wild_shape",
            "amount": 1
          }
        ],
        "requirements": [
          {
            "type": "creature_type",
            "value": ["Beast"]
          },
          {
            "type": "cr",
            "comparison": "at_most",
            "value": "scaling.cr"
          },
          {
            "type": "speed",
            "category": "flying",
            "comparison": "equals",
            "value": "scaling.flying_speed"
          },
          {
            "type": "speed",
            "category": "swimming",
            "comparison": "equals",
            "value": "scaling.swimming_speed"
          }
        ],
        "effects": [
          {
            "apply_status": {
              "id": "status:wild-shape",
              "duration": {
                "calculation": {
                  "operation": "divide",
                  "operators": [
                    { "type": "class_level", "class": "Druid" },
                    { "type": "integer", "value": 2 }
                  ],
                  "rounding": "down"
                },
                "unit": "hours",
                "until": [
                  {
                    "event": ["status_removed"],
                    "status": {
                      "name": "wild-shape",
                      "method": "voluntary"
                    }
                  }
                ]
              },
              "transform": {
                "type": "beast",
                "retain": {
                  "ability_scores": ["Intelligence", "Wisdom", "Charisma"],
                  "proficiencies": ["skills", "saving_throws"],
                  "features": true
                },
                "trigger": {
                  "event": ["damaged_by"],
                  "damage": {
                    "lethal": true
                  },
                  "result": "revert"
                },
                "constraints": {
                  "actions": {
                    "blocked": {
                      "triggers": ["cast_spell"]
                    }
                  }
                }
              }
            }
          }
        ],
        "scaling": {
          "components": {
            "cr": {
              "by_level": {
                "2": 0.25,
                "4": 0.5,
                "8": 1
              }
            },
            "flying_speed": {
              "by_level": {
                "2": 0,
                "8": null
              }
            },
            "swimming_speed": {
              "by_level": {
                "2": 0,
                "4": null
              }
            }
          }
        }
      }
    ],
    "source": "phb",
    "ruleset": "dnd5e"
  },
  {
    "id": "feat:wild-companion",
    "class": "class:druid",
    "level": 2,
    "name": "Wild Companion",
    "description": "You gain the ability to summon a spirit that assumes an animal form: as an action, you can expend a use of your Wild Shape feature to cast the find familiar spell, without material components. When you cast the spell in this way, the familiar is a fey instead of a beast, and the familiar disappears after a number of hours equal to half your druid level (rounded down).",
    "mechanics": [
      {
        "type": "action",
        "cost": [
          {
            "resource": "wild_shape",
            "amount": 1
          }
        ],
        "grants": {
          "name": "Wild Companion",
          "interaction": {
            "type": "spell",
            "spell": "spell:find-familiar",
            "ignore_requirements": ["material"],
            "overrides": {
              "creature_type": "Fey",
              "duration": {
                "calculation": {
                  "operation": "divide",
                  "operators": [
                    { "type": "class_level", "class": "Druid" },
                    { "type": "integer", "value": 2 }
                  ],
                  "rounding": "down"
                },
                "unit": "hours"
              }
            }
          }
        }
      }
    ],
    "source": "tce",
    "ruleset": "dnd5e"
  },
