          {
            "type": "bonus_action",
            "cost": [
              {
                "resource": "wild_shape",
                "amount": 1
              }
            ],
            "uses": { "value": 1 },
            "recharge": "short_rest",
            "effects": [
              {
                "aura": {
                  "origin": "point",
                  "radius": 30,
                  "unit": "feet",
                  "target": {
