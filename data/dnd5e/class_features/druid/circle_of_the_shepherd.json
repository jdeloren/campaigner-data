  {
    "id": "feat:mighty-summoner",
    "class": "subclass:circle-of-the-shepherd",
    "level": 6,
    "name": "Mighty Summoner",
    "description": "Beasts and fey that you conjure are more resilient than normal. Any beast or fey summoned or created by a spell that you cast gains the following benefits: the creature appears with more hit points than normal: 2 extra hit points per Hit Die it has. The natural weapons of the creature are considered magical for the purpose of overcoming immunity and resistance to nonmagical attacks and damage.",
    "mechanics": [
      {
        "type": "passive",
        "requirements": [
          {
            "operator": "or",
            "conditions": [
              { "type": "creature_type", "value": ["Beast"] },
              { "type": "creature_type", "value": ["Fey"] }
            ]
          }
        ],
        "effects": [
          {
            "attribute": {
              "category": "combat",
              "property": "magical",
              "calculation": {
                "operation": "set",
                "operators": [{ "type": "boolean", "value": true }]
              }
            }
          }
        ]
      },
      {
        "type": "passive",
        "requirements": [
          {
            "operator": "or",
            "conditions": [
              { "type": "creature_type", "value": ["Beast"] },
              { "type": "creature_type", "value": ["Fey"] }
            ]
          }
        ],
        "effects": [
          {
            "attribute": {
              "target": "hit_points.maximum",
              "calculation": {
                "operation": "add",
                "operators": [
                  { "type": "attribute", "value": "hit_points.maximum" },
                  {
                    "type": "calculation",
                    "operation": "multiply",
                    "operators": [
                      { "type": "attribute", "value": "hit_dice.count" },
                      { "type": "integer", "value": 2 }
                    ]
                  }
                ]
              }
            }
          }
        ]
      }
    ],
    "source": "xge",
    "ruleset": "dnd5e"
  },
  {
    "id": "feat:guardian-spirit",
    "class": "subclass:circle-of-the-shepherd",
    "level": 10,
    "name": "Guardian Spirit",
    "description": "Your Spirit Totem safeguards the beasts and fey that you call forth with your magic. When a beast or fey that you summoned or created with a spell ends its turn in your Spirit Totem aura, that creature regains a number of hit points equal to half your druid level.",
    "mechanics": [
      {
        "type": "passive",
        "trigger": {
          "event": ["turn_end"],
          "target": {
            "type": "creature",
            "requirements": [
              {
                "operator": "or",
                "conditions": [
                  { "type": "creature_type", "value": ["Beast"] },
                  { "type": "creature_type", "value": ["Fey"] }
                ]
              }
            ]
          }
        },
        "effects": [
          {
            "healing": {
              "calculation": {
                "operation": "divide",
                "operators": [
                  { "type": "class_level", "class": "Druid" },
                  { "type": "integer", "value": 2 }
                ],
                "rounding": "down"
              }
            }
          }
        ]
      }
    ],
    "source": "xge",
    "ruleset": "dnd5e"
  },
  {
    "id": "feat:faithful-summons",
    "class": "subclass:circle-of-the-shepherd",
    "level": 14,
    "name": "Faithful Summons",
    "description": "The nature spirits you commune with protect you when you are the most defenseless. If you are reduced to 0 hit points or are incapacitated against your will, you can immediately gain the effect of conjure animals as if it were cast using a 9th-level spell slot. It summons four beasts of your choice that are challenge rating 2 or lower. The conjured beasts appear within 20 feet of you. If they receive no commands from you, they protect you from harm and attack your foes. The spell lasts for 1 hour, requiring no concentration, and you can't use it again until you finish a long rest.",
    "mechanics": [
      {
        "type": "passive",
        "trigger": {
          "event": ["damaged_by"],
          "damage": {
            "lethal": true
          }
        },
        "uses": { "value": 1 },
        "recharge": "long_rest",
        "grants": {
          "name": "Faithful Summons",
          "interaction": {
            "type": "spell",
            "spell": "spell:conjure-animals",
            "slot": false,
            "overrides": {
              "duration": {
                "value": 1,
                "unit": "hours"
              }
            }
          }
        }
      }
    ],
    "source": "xge",
    "ruleset": "dnd5e"
  }
]
