  {
    "id": "feat:undead-thralls",
    "class": "subclass:necromancy",
    "level": 6,
    "name": "Undead Thralls",
    "description": "At 6th level, you add the animate dead spell to your spellbook if it is not there already. When you cast animate dead, you can target one additional corpse or pile of bones, creating another zombie or skeleton, as appropriate.\n\nWhenever you create an undead using a necromancy spell, it has additional benefits:\n- The creature's hit point maximum is increased by an amount equal to your wizard level.\n- The creature adds your proficiency bonus to its weapon damage rolls.",
    "mechanics": [
      {
        "type": "granted_spells",
        "spells": ["spell:animate-dead"],
        "always_prepared": true
      },
      {
        "type": "passive",
        "name": "undead_thralls_extra_target",
        "description": "When you cast animate dead, you can target one additional corpse or pile of bones.",
        "trigger": {
          "event": ["cast_spell"],
          "source": {
            "type": "spell",
            "id": "spell:animate-dead"
          }
        },
        "effects": [
          {
            "attribute": {
              "target": "spell.target_count",
              "calculation": {
                "operation": "add",
                "operators": [
                  {
                    "type": "integer",
                    "value": 1
                  }
                ]
              }
            }
          }
        ]
      },
      {
        "type": "passive",
        "name": "undead_thralls_hp",
        "description": "Undead you create with necromancy spells gain hit points equal to your wizard level.",
        "trigger": {
          "event": ["cast_spell"],
          "source": {
            "type": "spell",
            "school": "Necromancy"
          }
        },
        "effects": [
          {
            "buff": {
              "category": "hit_points",
              "property": "maximum",
              "bonus": {
                "operation": "add",
                "operators": [
                  {
                    "type": "class_level",
                    "class": "class:wizard"
                  }
                ]
              }
            }
          }
        ]
      },
      {
        "type": "passive",
        "name": "undead_thralls_damage",
        "description": "Undead you create with necromancy spells add your proficiency bonus to weapon damage rolls.",
        "trigger": {
          "event": ["cast_spell"],
          "source": {
            "type": "spell",
            "school": "Necromancy"
          }
        },
        "effects": [
          {
            "damage_bonus": {
              "calculation": {
                "operation": "add",
                "operators": [
                  {
                    "type": "function",
                    "function": "levels.calculate_proficiency_bonus",
                    "context": "character"
                  }
                ]
              },
              "inherit_type": true
            }
          }
        ]
      }
    ],
    "source": "phb",
    "ruleset": "dnd5e"
  },
  {
    "id": "feat:inured-to-undeath",
    "class": "subclass:necromancy",
    "level": 10,
    "name": "Inured to Undeath",
    "description": "Beginning at 10th level, you have resistance to necrotic damage, and your hit point maximum can't be reduced. You have spent so much time dealing with undead and the forces that animate them that you have become inured to some of their worst effects.",
    "mechanics": [
      {
        "type": "resistance",
        "name": "necrotic_resistance",
        "effects": [
          {
            "damage_response": {
              "category": "resistance",
              "to": ["necrotic"]
            }
          }
        ]
      },
      {
        "type": "immunity",
        "name": "hp_max_reduction_immunity",
        "effects": [
          {
            "immunity": {
              "category": "hit_points",
              "property": "maximum",
              "effect": "reduction"
            }
          }
        ]
      }
    ],
    "source": "phb",
    "ruleset": "dnd5e"
  },
  {
    "id": "feat:command-undead",
    "class": "subclass:necromancy",
    "level": 14,
    "name": "Command Undead",
    "description": "Starting at 14th level, you can use magic to bring undead under your control, even those created by other wizards. As an action, you can choose one undead that you can see within 60 feet of you. That creature must make a Charisma saving throw against your wizard spell save DC. If it succeeds, you can't use this feature on it again. If it fails, it becomes friendly to you and obeys your commands until you use this feature again.\n\nIntelligent undead are harder to control in this way. If the target has an Intelligence of 8 or higher, it has advantage on the saving throw. If it fails the saving throw and has an Intelligence of 12 or higher, it can repeat the saving throw at the end of every hour until it succeeds and frees itself.",
    "mechanics": [
      {
        "type": "action",
        "name": "command_undead",
        "target": {
          "type": "creature",
          "count": 1,
          "requirements": [
            {
              "type": "creature_type",
              "value": ["undead"]
            },
            {
              "type": "perception",
              "observer": "character",
              "subject": "target",
              "senses": ["sight"]
            }
          ]
        },
        "range": {
          "value": 60,
          "unit": "feet"
        },
        "saving_throw": {
          "ability": ["Charisma"],
          "dc": {
            "ref": "spell_save_dc"
          },
          "advantage": {
            "requirements": [
              {
                "type": "attribute",
                "attribute": "Intelligence",
                "range": {
                  "minimum": 8
                }
              }
            ]
          }
        },
        "on_failure": {
          "apply_status": {
            "id": "status:charmed",
            "source": "character",
            "duration": {
              "until": ["feature_reuse"]
            }
          }
        },
        "on_success": {
          "recharge": {
            "value": 24,
            "unit": "hours"
          }
        }
      }
    ],
    "source": "phb",
    "ruleset": "dnd5e"
  }
]
