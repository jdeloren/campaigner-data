                    "value": 2
                  }
                ]
              }
            }
          }
        ]
      },
      {
        "type": "passive",
        "name": "grim_harvest_necromancy",
        "description": "Healing increases to three times the spell's level for necromancy spells.",
        "trigger": {
          "event": ["kill"],
