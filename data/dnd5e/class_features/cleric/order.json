              "id": "status:orders-wrath",
              "source": "character",
              "duration": {
                "value": 1,
                "unit": "turns",
                "timing": "start_turn"
              },
              "effects": [
                {
                  "damage": {
                    "bonus": {
                      "operation": "add",
                      "operators": [
                        {
