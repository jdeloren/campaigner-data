[
  {
    "id": "feat:twilight-domain-spells",
    "level": 1,
    "name": "Domain Spells",
    "description": "You gain domain spells at the cleric levels listed. Once you gain a domain spell, you always have it prepared, and it doesn't count against the number of spells you can prepare each day.",
    "source": "tce",
    "ruleset": "dnd5e",
    "class": "domain:twilight",
    "mechanics": [
      {
        "type": "granted_spells",
        "always_prepared": true,
        "scaling": {
          "by_level": {
            "1": [
              "spell:faerie-fire",
              "spell:sleep"
            ],
            "3": [
              "spell:moonbeam",
              "spell:see-invisibility"
            ],
            "5": [
              "spell:aura-of-vitality",
              "spell:leomunds-tiny-hut"
            ],
            "7": [
              "spell:aura-of-life",
              "spell:greater-invisibility"
            ],
            "9": [
              "spell:circle-of-power",
              "spell:mislead"
            ]
          }
        }
      }
    ]
  },
