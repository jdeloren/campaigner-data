  {
    "id": "feat:twilight-eyes-of-night",
    "level": 1,
    "name": "Eyes of Night",
    "description": "You can see through the deepest gloom. You have darkvision out to a range of 300 feet. In that radius, you can see in dim light as if it were bright light and in darkness as if it were dim light.\n\nAs an action, you can magically share the darkvision of this feature with willing creatures you can see within 10 feet of you, up to a number of creatures equal to your Wisdom modifier (minimum of one creature). The shared darkvision lasts for 1 hour. Once you share it, you can't do so again until you finish a long rest, unless you expend a spell slot of any level to share it again.",
    "source": "tce",
    "ruleset": "dnd5e",
    "class": "domain:twilight",
    "mechanics": [
      {
        "type": "passive",
        "name": "eyes_of_night_darkvision",
        "effects": [
          {
            "attribute": {
              "target": "senses.darkvision",
              "calculation": {
                "operation": "set",
                "operators": [
                  {
                    "type": "integer",
                    "value": 300
                  }
                ]
              }
            }
          }
        ]
      },
      {
        "type": "action",
        "name": "eyes_of_night_share",
        "target": {
          "type": "creature",
          "count": {
            "type": "ability_modifier",
            "ability": "Wisdom",
            "bounds": {
              "minimum": 1
            }
          },
          "disposition": "willing",
          "choice": true
        },
        "range": {
          "value": 10,
          "unit": "feet"
        },
        "effects": [
          {
            "attribute": {
              "target": "senses.darkvision",
              "calculation": {
                "operation": "set",
                "operators": [
                  {
                    "type": "integer",
                    "value": 300
                  }
                ]
              }
            }
          }
        ],
        "duration": {
          "value": 1,
          "unit": "hours"
        },
        "uses": {
          "value": 1
        },
        "recharge": "long_rest"
      }
    ]
  },
  {
    "id": "feat:twilight-vigilant-blessing",
    "level": 1,
    "name": "Vigilant Blessing",
    "description": "At 1st level, the night has taught you to be vigilant. As an action, you give one creature you touch (including possibly yourself) advantage on the next initiative roll the creature makes. This benefit ends immediately after the roll or if you use this feature again.",
    "source": "tce",
    "ruleset": "dnd5e",
    "class": "domain:twilight",
    "mechanics": [
      {
        "type": "action",
        "name": "vigilant_blessing",
        "target": {
          "type": "creature",
          "count": 1
        },
        "range": {
          "value": 0,
          "unit": "feet"
        },
        "effects": [
