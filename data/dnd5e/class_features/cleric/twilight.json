                  }
                }
              ]
            }
          }
        ]
      }
    ]
  },
  {
    "id": "feat:twilight-twilight-sanctuary",
    "level": 2,
    "name": "Twilight Sanctuary",
    "description": "At 2nd level, you can use your Channel Divinity to refresh your allies with soothing twilight.\n\nAs an action, you present your holy symbol, and a sphere of twilight emanates from you. The sphere is centered on you, has a 30-foot radius, and is filled with dim light. The sphere moves with you, and it lasts for 1 minute or until you are incapacitated or die. Whenever a creature (including you) ends its turn in the sphere, you can grant that creature one of these benefits:\n\n- You grant it temporary hit points equal to 1d6 plus your cleric level.\n- You end one effect on it causing it to be charmed or frightened.",
    "source": "tce",
    "ruleset": "dnd5e",
    "class": "domain:twilight",
    "mechanics": [
      {
        "type": "action",
        "name": "twilight_sanctuary",
        "cost": [
          {
            "resource": "channel_divinity",
            "amount": 1
          }
        ],
        "area": {
          "shape": "sphere",
          "size": 30
        },
        "duration": {
          "value": 1,
          "unit": "minutes"
        },
        "effects": [
          {
            "choice": {
              "options": [
                {
                  "name": "Temporary Hit Points",
                  "effect": {
                    "healing": {
                      "dice": "1d6",
                      "bonus": {
                        "operation": "add",
                        "operators": [
                          {
                            "type": "class_level",
                            "class": "class:cleric"
                          }
                        ]
                      },
                      "barrier": {
                        "priority": 1
                      }
                    }
                  }
                },
                {
                  "name": "End Charmed or Frightened",
                  "effect": {
                    "negate": [
                      "charmed",
                      "frightened"
                    ]
                  }
                }
              ]
            }
          }
        ]
      }
    ]
  },
  {
    "id": "feat:twilight-steps-of-night",
    "level": 6,
    "name": "Steps of Night",
    "description": "Starting at 6th level, you can draw on the mystical power of night to rise into the air. As a bonus action when you are in dim light or darkness, you can magically give yourself a flying speed equal to your walking speed for 1 minute. You can use this feature a number of times equal to your proficiency bonus, and you regain all expended uses when you finish a long rest.",
    "source": "tce",
    "ruleset": "dnd5e",
    "class": "domain:twilight",
    "mechanics": [
      {
        "type": "bonus_action",
        "name": "steps_of_night",
        "requirements": [
          {
            "type": "environment",
            "lighting": "dim_light"
          }
        ],
        "effects": [
