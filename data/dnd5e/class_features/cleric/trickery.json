  {
    "id": "feat:trickery-divine-strike",
    "level": 8,
    "name": "Divine Strike",
    "description": "You gain the ability to infuse your weapon strikes with divine energy. Once on each of your turns when you hit a creature with a weapon attack, you can cause the attack to deal an extra 1d8 poison damage to the target. When you reach 14th level, the extra damage increases to 2d8.",
    "source": "phb",
    "ruleset": "dnd5e",
    "class": "domain:trickery",
    "mechanics": [
      {
        "type": "damage_bonus",
        "trigger": {
