[
  {
    "id": "feat:life-domain-spells",
    "level": 1,
    "name": "Domain Spells",
    "description": "You gain domain spells at the cleric levels listed. Once you gain a domain spell, you always have it prepared, and it doesn't count against the number of spells you can prepare each day.",
    "source": "phb",
    "ruleset": "dnd5e",
    "class": "domain:life",
    "mechanics": [
      {
        "type": "granted_spells",
        "always_prepared": true,
        "scaling": {
          "by_level": {
            "1": [
              "spell:bless",
              "spell:cure-wounds"
            ],
            "3": [
              "spell:lesser-restoration",
              "spell:spiritual-weapon"
            ],
            "5": [
              "spell:beacon-of-hope",
              "spell:revivify"
            ],
            "7": [
              "spell:death-ward",
              "spell:guardian-of-faith"
            ],
            "9": [
              "spell:mass-cure-wounds",
              "spell:raise-dead"
            ]
          }
        }
      }
    ]
  },
  {
    "id": "feat:life-bonus-proficiency",
