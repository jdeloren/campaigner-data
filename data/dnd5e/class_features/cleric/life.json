  {
    "id": "feat:life-disciple-of-life",
    "level": 1,
    "name": "Disciple of Life",
    "description": "Your healing spells are more effective. Whenever you use a spell of 1st level or higher to restore hit points to a creature, the creature regains additional hit points equal to 2 + the spell's level.",
    "source": "phb",
    "ruleset": "dnd5e",
    "class": "domain:life",
    "mechanics": [
      {
        "type": "passive",
        "trigger": {
          "event": [
            "cast_spell"
          ],
          "spell": {
            "effect": [
              "healing"
            ]
          }
        },
        "requirements": [
          {
            "type": "spell",
            "level": {
              "minimum": 1
            }
          }
        ],
        "effects": [
          {
            "healing": {
              "calculation": {
                "operation": "add",
                "operators": [
                  {
                    "type": "integer",
                    "value": 2
                  },
                  {
                    "type": "spell_level_cast"
                  }
                ]
              }
            }
          }
        ]
      }
    ]
  },
  {
    "id": "feat:life-preserve-life",
    "level": 2,
    "name": "Preserve Life",
    "description": "You can use your Channel Divinity to heal the badly injured. As an action, you present your holy symbol and evoke healing energy that can restore a number of hit points equal to five times your cleric level. Choose any creatures within 30 feet of you, and divide those hit points among them. This feature can restore a creature to no more than half of its hit point maximum. You can't use this feature on an undead or a construct.",
    "source": "phb",
    "ruleset": "dnd5e",
    "class": "domain:life",
    "mechanics": [
      {
        "type": "action",
        "cost": [
          {
            "resource": "channel_divinity",
            "amount": 1
          }
        ],
        "requirements": [
          {
            "type": "equipment",
            "item": [
              "holy symbol"
            ]
          }
        ],
        "effects": [
          {
            "target": {
              "type": "creatures",
              "disposition": "any",
              "requirements": [
                {
                  "type": "creature_type",
                  "value": [
                    "Undead",
                    "Construct"
                  ],
                  "negate": true
                },
                {
                  "type": "attribute",
                  "ref": "hit_points.current",
                  "comparison": "less_than",
                  "calculation": {
                    "operation": "divide",
                    "operators": [
                      {
                        "type": "attribute",
                        "value": "max_hit_points"
                      },
                      {
                        "type": "integer",
                        "value": 2
                      }
                    ]
                  }
                }
              ]
            },
            "area": {
              "shape": "radius",
              "size": 30,
              "unit": "feet",
              "origin": "self"
            },
            "player_choice": true,
            "healing": {
              "calculation": {
                "operation": "multiply",
                "operators": [
                  {
                    "type": "integer",
                    "value": 5
                  },
                  {
                    "type": "class_level",
                    "class": "class:cleric"
                  }
                ]
              },
              "distribution": "player_allocation"
            }
          }
        ]
      }
    ]
  },
  {
    "id": "feat:life-blessed-healer",
    "name": "Blessed Healer",
    "level": 6,
    "description": "The healing spells you cast on others heal you as well. Beginning at 6th level, when you cast a spell of 1st level or higher that restores hit points to a creature other than you, you regain hit points equal to 2 + the spell's level.",
    "source": "phb",
    "ruleset": "dnd5e",
