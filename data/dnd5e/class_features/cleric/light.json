[
  {
    "id": "feat:light-domain-spells",
    "level": 1,
    "name": "Domain Spells",
    "description": "You gain domain spells at the cleric levels listed. Once you gain a domain spell, you always have it prepared, and it doesn't count against the number of spells you can prepare each day.",
    "source": "phb",
    "ruleset": "dnd5e",
    "class": "domain:light",
    "mechanics": [
      {
        "type": "granted_spells",
        "always_prepared": true,
        "scaling": {
          "by_level": {
            "1": [
              "spell:burning-hands",
              "spell:faerie-fire"
            ],
            "3": [
              "spell:flaming-sphere",
              "spell:scorching-ray"
            ],
            "5": [
              "spell:daylight",
              "spell:fireball"
            ],
            "7": [
              "spell:guardian-of-faith",
              "spell:wall-of-fire"
            ],
            "9": [
              "spell:flame-strike",
              "spell:scrying"
            ]
          }
        }
      }
    ]
  },
  {
    "id": "feat:light-bonus-cantrip",
    "level": 1,
    "name": "Bonus Cantrip",
    "description": "You gain the Light cantrip if you don't already know it. This cantrip doesn't count against the number of cleric cantrips you know.",
    "source": "phb",
    "ruleset": "dnd5e",
    "class": "domain:light",
    "mechanics": [
      {
        "type": "granted_spells",
        "spells": [
          "spell:light"
        ]
      }
    ]
  },
  {
    "id": "feat:light-warding-flare",
    "level": 1,
    "name": "Warding Flare",
    "description": "You can interpose divine light between yourself and an attacking enemy.",
    "source": "phb",
    "ruleset": "dnd5e",
    "class": "domain:light",
    "mechanics": [
      {
        "type": "reaction",
        "trigger": {
          "event": [
