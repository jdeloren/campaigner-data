  {
    "id": "feat:light-radiance-of-the-dawn",
    "name": "Radiance of the Dawn",
    "level": 2,
    "description": "You can use your Channel Divinity to harness sunlight, banishing darkness and dealing radiant damage to your foes. As an action, you present your holy symbol, and any magical darkness within 30 feet of you is dispelled. Additionally, each hostile creature within 30 feet of you must make a Constitution saving throw. A creature takes radiant damage equal to 2d10 + your cleric level on a failed saving throw, and half as much damage on a successful one. A creature that has total cover from you is not affected.",
    "source": "phb",
    "ruleset": "dnd5e",
    "class": "domain:light",
    "mechanics": [
      {
        "type": "action",
        "cost": [
          {
            "resource": "channel_divinity",
            "amount": 1
          }
        ],
        "requirements": [
          {
            "type": "equipment",
            "item": [
              "holy symbol"
            ]
          }
        ],
        "effects": [
          {
            "area": {
              "shape": "radius",
              "size": 30,
              "unit": "feet",
              "origin": "self"
            },
            "negate": [
              "magical_darkness"
            ]
          },
          {
            "target": {
              "type": "creatures",
              "disposition": "hostile"
            },
            "area": {
              "shape": "radius",
              "size": 30,
              "unit": "feet",
              "origin": "self"
            },
            "blocked_by": {
              "cover": "total"
            },
            "saving_throw": {
              "ability": [
                "Constitution"
              ],
              "dc": {
                "ref": "spell_save_dc"
              },
              "on_success": {
                "damage": {
                  "calculation": {
                    "operation": "divide",
                    "operators": [
                      {
                        "type": "integer",
                        "value": 2
                      }
                    ],
                    "rounding": "down"
                  }
                }
              },
              "on_failure": {
                "damage": {
                  "dice": "2d10",
                  "bonus": {
                    "operation": "add",
                    "operators": [
                      {
                        "type": "class_level",
