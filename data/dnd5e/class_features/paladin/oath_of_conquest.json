                    ]
                  }
                }
              }
            }
          },
          {
            "aura": {
              "radius": 10,
              "unit": "feet",
              "target": {
                "type": "creatures",
                "disposition": "hostile",
                "requirements": [
                  {
                    "type": "status",
                    "value": "frightened",
                    "source": "character"
                  }
                ]
              },
              "grants": {
                "attribute": {
                  "target": "hit_points.current",
                  "calculation": {
                    "operation": "subtract",
                    "operators": [
                      {
                        "type": "calculation",
                        "operation": "divide",
                        "operators": [
                          {
                            "type": "class_level",
                            "class": "class:paladin"
                          },
                          {
                            "type": "integer",
                            "value": 2
                          }
                        ],
                        "rounding": "down"
                      }
                    ]
                  }
                }
              }
            }
          }
        ],
        "scaling": {
          "components": {
