[
  {
    "id": "feat:oath-of-conquest-oath-spells",
    "class": "subclass:oath-of-conquest",
    "level": 3,
    "name": "Oath Spells",
    "description": "You gain oath spells at the paladin levels listed. Once you gain an oath spell, you always have it prepared, and it doesn't count against the number of spells you can prepare each day. If you have an oath spell that doesn't appear on the paladin spell list, the spell is nonetheless a paladin spell for you.",
    "mechanics": [
      {
        "type": "granted_spells",
        "always_prepared": true,
        "scaling": {
          "by_level": {
            "3": ["spell:armor-of-agathys", "spell:command"],
            "5": ["spell:hold-person", "spell:spiritual-weapon"],
            "9": ["spell:bestow-curse", "spell:fear"],
            "13": ["spell:dominate-beast", "spell:stoneskin"],
            "17": ["spell:cloudkill", "spell:dominate-person"]
          }
        }
      }
    ],
    "source": "xge",
    "ruleset": "dnd5e"
  },
  {
    "id": "feat:oath-of-conquest-conquering-presence",
    "class": "subclass:oath-of-conquest",
    "level": 3,
    "name": "Channel Divinity: Conquering Presence",
    "description": "You can use your Channel Divinity to exude a terrifying presence. As an action, you force each creature of your choice that you can see within 30 feet of you to make a Wisdom saving throw. On a failed save, a creature becomes frightened of you for 1 minute. The frightened creature can repeat this saving throw at the end of each of its turns, ending the effect on itself on a success.",
    "mechanics": [
      {
        "type": "action",
        "cost": [
          {
            "resource": "channel_divinity",
            "amount": 1
          }
        ],
        "effects": [
          {
            "target": {
              "type": "creatures",
              "disposition": "any",
              "requirements": [
                {
                  "type": "perception",
                  "observer": "character",
                  "subject": "target",
                  "senses": ["sight"]
                }
              ]
            },
            "area": {
              "shape": "radius",
              "size": 30,
              "unit": "feet",
              "origin": "self"
            },
            "saving_throw": {
              "ability": ["Wisdom"],
              "dc": {
                "ref": "spell_save_dc"
              },
              "on_failure": {
                "apply_status": {
                  "id": "status:frightened",
                  "source": "character",
                  "duration": {
                    "value": 1,
                    "unit": "minutes"
                  },
                  "escape": {
                    "ability": ["Wisdom"],
                    "dc": {
                      "ref": "spell_save_dc"
                    }
                  }
                }
              }
            }
          }
        ]
      }
    ],
    "source": "xge",
    "ruleset": "dnd5e"
  },
  {
    "id": "feat:oath-of-conquest-guided-strike",
    "class": "subclass:oath-of-conquest",
    "level": 3,
    "name": "Channel Divinity: Guided Strike",
    "description": "You can use your Channel Divinity to strike with supernatural accuracy. When you make an attack roll, you can use your Channel Divinity to gain a +10 bonus to the roll. You make this choice after you see the roll, but before the DM says whether the attack hits or misses.",
    "mechanics": [
      {
        "type": "optional",
        "trigger": {
          "event": ["attack"],
          "timing": "before"
        },
        "cost": [
          {
            "resource": "channel_divinity",
            "amount": 1
          }
        ],
        "effects": [
          {
            "calculation": {
              "operation": "add",
              "operators": [
                {
                  "type": "integer",
                  "value": 10
                }
              ]
            }
          }
        ]
      }
    ],
    "source": "xge",
    "ruleset": "dnd5e"
  },
  {
    "id": "feat:oath-of-conquest-aura-of-conquest",
    "class": "subclass:oath-of-conquest",
    "level": 7,
    "name": "Aura of Conquest",
    "description": "Starting at 7th level, you constantly emanate a menacing aura while you're not incapacitated. The aura extends 10 feet from you in every direction, but not through total cover.\n\nIf a creature is frightened of you, its speed is reduced to 0 while in the aura, and that creature takes psychic damage equal to half your paladin level (rounded down) if it starts its turn there.\n\nAt 18th level, the range of this aura increases to 30 feet.",
    "mechanics": [
      {
        "type": "passive",
        "requirements": [
          {
            "type": "status",
            "value": "incapacitated",
            "negate": true
          }
        ],
        "effects": [
          {
            "aura": {
              "radius": 10,
              "unit": "feet",
              "target": {
                "type": "creatures",
                "disposition": "hostile",
                "requirements": [
