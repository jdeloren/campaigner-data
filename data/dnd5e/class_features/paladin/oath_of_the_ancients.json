[
  {
    "id": "feat:oath-of-the-ancients-oath-spells",
    "class": "subclass:oath-of-the-ancients",
    "level": 3,
    "name": "Oath Spells",
    "description": "You gain oath spells at the paladin levels listed. Once you gain an oath spell, you always have it prepared, and it doesn't count against the number of spells you can prepare each day. If you have an oath spell that doesn't appear on the paladin spell list, the spell is nonetheless a paladin spell for you.",
    "mechanics": [
      {
        "type": "granted_spells",
        "always_prepared": true,
        "scaling": {
          "by_level": {
            "3": ["spell:ensnaring-strike", "spell:speak-with-animals"],
            "5": ["spell:moonbeam", "spell:misty-step"],
            "9": ["spell:plant-growth", "spell:protection-from-energy"],
            "13": ["spell:ice-storm", "spell:stoneskin"],
            "17": ["spell:commune-with-nature", "spell:tree-stride"]
          }
        }
      }
    ],
    "source": "phb",
    "ruleset": "dnd5e"
  },
  {
    "id": "feat:oath-of-the-ancients-natures-wrath",
    "class": "subclass:oath-of-the-ancients",
    "level": 3,
    "name": "Nature's Wrath",
    "description": "You can use your Channel Divinity to invoke primeval forces to ensnare a foe. As an action, you can cause spectral vines to spring up and reach for a creature within 10 feet of you that you can see. The creature must succeed on a Strength or Dexterity saving throw (its choice) or be restrained. While restrained by the vines, the creature repeats the saving throw at the end of each of its turns. On a success, it frees itself and the vines vanish.",
    "mechanics": [
      {
        "type": "action",
        "cost": [
          {
            "resource": "channel_divinity",
            "amount": 1
          }
        ],
        "target": {
          "type": "creature"
        },
        "range": {
          "value": 10,
          "unit": "feet"
        },
        "requirements": [
          {
            "type": "perception",
            "observer": "character",
            "subject": "target",
            "senses": ["sight"]
          }
        ],
        "effects": [
          {
            "saving_throw": {
              "ability": ["Strength", "Dexterity"],
              "dc": {
                "ref": "spell_save_dc"
              },
              "on_failure": {
                "apply_status": {
                  "id": "status:restrained",
                  "escape": {
                    "ability": ["Strength", "Dexterity"],
                    "dc": {
                      "ref": "spell_save_dc"
                    }
                  }
                }
              }
            }
          }
        ]
      }
    ],
    "source": "phb",
    "ruleset": "dnd5e"
  },
  {
    "id": "feat:oath-of-the-ancients-turn-the-faithless",
    "class": "subclass:oath-of-the-ancients",
    "level": 3,
    "name": "Turn the Faithless",
    "description": "You can use your Channel Divinity to utter ancient words that are painful for fey and fiends to hear. As an action, you present your holy symbol, and each fey or fiend within 30 feet of you that can hear you must make a Wisdom saving throw. On a failed save, the creature is turned for 1 minute or until it takes damage.\n\nA turned creature must spend its turns trying to move as far away from you as it can, and it can't willingly move to a space within 30 feet of you. It also can't take reactions. For its action, it can use only the Dash action or try to escape from an effect that prevents it from moving. If there's nowhere to move, the creature can use the Dodge action.\n\nIf the creature's true form is concealed by an illusion, shapeshifting, or other effect, that form is revealed while the creature is turned.",
    "mechanics": [
      {
        "type": "action",
        "cost": [
          {
            "resource": "channel_divinity",
            "amount": 1
          }
        ],
        "requirements": [
          {
            "type": "equipment",
            "item": ["holy symbol"]
          }
        ],
        "effects": [
          {
            "target": {
              "type": "creatures",
              "disposition": "any",
              "requirements": [
                {
                  "type": "creature_type",
                  "value": ["Fey", "Fiend"]
                },
                {
                  "type": "perception",
                  "observer": "target",
                  "subject": "character",
                  "senses": ["hearing"]
                }
              ]
            },
            "area": {
              "shape": "radius",
              "size": 30,
              "unit": "feet",
              "origin": "self"
            },
            "saving_throw": {
              "ability": ["Wisdom"],
              "dc": {
                "ref": "spell_save_dc"
              },
              "on_failure": {
                "apply_status": {
                  "id": "status:turned",
                  "duration": {
                    "value": 1,
                    "unit": "minutes",
                    "until": ["damaged_by"]
                  },
                  "constraints": {
                    "movement": {
                      "direction": "away",
                      "relative_to": "character",
                      "keep_distance": 30
                    },
                    "actions": {
                      "blocked": {
                        "economy": ["reaction"]
                      },
                      "allowed": {
                        "actions": ["Dash", "Dodge"]
                      }
                    }
                  }
                }
              }
            },
            "negate": ["illusion", "shapeshift"]
          }
        ]
      }
    ],
    "source": "phb",
    "ruleset": "dnd5e"
  },
  {
    "id": "feat:oath-of-the-ancients-aura-of-warding",
    "class": "subclass:oath-of-the-ancients",
    "level": 7,
    "name": "Aura of Warding",
    "description": "Beginning at 7th level, ancient magic lies so heavily upon you that it forms an eldritch ward. You and friendly creatures within 10 feet of you have resistance to damage from spells.\n\nAt 18th level, the range of this aura increases to 30 feet.",
    "mechanics": [
      {
        "type": "passive",
        "effects": [
          {
            "aura": {
              "radius": 10,
              "unit": "feet",
              "target": {
                "type": "creatures",
                "disposition": "friendly",
                "include_self": true
              },
              "grants": {
                "damage_response": {
                  "category": "resistance",
                  "source": {
                    "type": ["spell"]
                  }
                }
              }
            }
          }
        ],
        "scaling": {
          "components": {
            "aura.radius": {
              "by_level": {
                "7": 10,
                "18": 30
              }
            }
          }
        }
      }
    ],
    "source": "phb",
    "ruleset": "dnd5e"
  },
  {
    "id": "feat:oath-of-the-ancients-undying-sentinel",
    "class": "subclass:oath-of-the-ancients",
    "level": 15,
    "name": "Undying Sentinel",
    "description": "Starting at 15th level, when you are reduced to 0 hit points and are not killed outright, you can choose to drop to 1 hit point instead. Once you use this ability, you can't use it again until you finish a long rest.\n\nAdditionally, you suffer none of the drawbacks of old age, and you can't be aged magically.",
    "mechanics": [
      {
        "type": "passive",
        "trigger": {
          "event": ["damaged_by"],
          "damage": {
            "lethal": true
          }
        },
        "effects": [
          {
            "attribute": {
              "target": "hit_points.current",
              "calculation": {
                "operation": "set",
                "operators": [
                  {
                    "type": "integer",
                    "value": 1
                  }
                ]
              }
            }
          }
        ],
        "uses": {
          "value": 1
        },
        "recharge": "long_rest"
      },
      {
        "type": "special",
        "name": "ageless",
        "description": "You suffer none of the drawbacks of old age, and you can't be aged magically."
      }
    ],
    "source": "phb",
    "ruleset": "dnd5e"
  },
  {
    "id": "feat:oath-of-the-ancients-elder-champion",
    "class": "subclass:oath-of-the-ancients",
    "level": 20,
    "name": "Elder Champion",
    "description": "At 20th level, you can assume the form of an ancient force of nature, taking on an appearance you choose. For example, your skin might turn green or take on a bark-like texture, your hair might become leafy or moss-like, or you might sprout antlers or a lion-like mane.\n\nUsing your action, you undergo a transformation. For 1 minute, you gain the following benefits:\n\n- At the start of each of your turns, you regain 10 hit points.\n- Whenever you cast a paladin spell that has a casting time of 1 action, you can cast it using a bonus action instead.\n- Enemy creatures within 10 feet of you have disadvantage on saving throws against your paladin spells and Channel Divinity options.",
    "mechanics": [
      {
        "type": "action",
        "effects": [
          {
            "apply_status": {
              "id": "status:elder-champion",
              "duration": {
                "value": 1,
                "unit": "minutes"
              }
            }
          }
        ],
        "uses": {
          "value": 1
        },
        "recharge": "long_rest"
      }
    ],
    "subfeatures": [
      {
        "name": "Regeneration",
        "description": "At the start of each of your turns, you regain 10 hit points.",
        "mechanics": [
          {
            "type": "passive",
            "trigger": {
              "event": ["turn_start"]
            },
            "requirements": [
              {
                "type": "status",
                "value": "elder-champion"
              }
            ],
            "effects": [
              {
                "healing": {
                  "value": 10
                },
                "target": {
                  "type": "self"
                }
              }
            ]
          }
        ]
      },
      {
        "name": "Quickened Casting",
        "description": "Whenever you cast a paladin spell that has a casting time of 1 action, you can cast it using a bonus action instead.",
        "mechanics": [
          {
            "type": "passive",
            "requirements": [
              {
                "type": "status",
                "value": "elder-champion"
              }
            ],
            "effects": [
              {
                "attribute": {
                  "target": "spellcasting.casting_time",
                  "calculation": {
                    "operation": "set",
                    "operators": [
                      {
                        "type": "string",
                        "value": "bonus_action"
                      }
                    ]
                  }
                }
              }
            ]
          }
        ]
      },
      {
        "name": "Aura of Dread",
        "description": "Enemy creatures within 10 feet of you have disadvantage on saving throws against your paladin spells and Channel Divinity options.",
        "mechanics": [
          {
            "type": "passive",
            "requirements": [
              {
                "type": "status",
                "value": "elder-champion"
              }
            ],
            "effects": [
              {
                "aura": {
                  "radius": 10,
                  "unit": "feet",
                  "target": {
                    "type": "creatures",
                    "disposition": "hostile"
                  },
                  "grants": {
                    "disadvantage": {
                      "saving_throw": ["Strength", "Dexterity", "Constitution", "Intelligence", "Wisdom", "Charisma"]
                    }
                  }
                }
              }
            ]
          }
        ]
      }
    ],
    "source": "phb",
