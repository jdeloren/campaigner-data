                        "dice": "4d10"
                      }
                    ]
                  }
                }
              }
            }
          },
          {
            "aura": {
              "origin": "self",
              "radius": 30,
              "unit": "feet",
              "target": {
                "type": "creatures",
                "disposition": "friendly",
                "include_self": true
              },
              "grants": {
                "disadvantage": {
                  "attack": "all"
