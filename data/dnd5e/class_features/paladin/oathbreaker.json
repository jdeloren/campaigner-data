  {
    "id": "feat:oathbreaker-aura-of-hate",
    "class": "subclass:oathbreaker",
    "level": 7,
    "name": "Aura of Hate",
    "description": "Starting at 7th level, the paladin, as well as any fiends and undead within 10 feet of the paladin, gains a bonus to melee weapon damage rolls equal to the paladin's Charisma modifier (minimum of +1). A creature can benefit from this feature from only one paladin at a time.\n\nAt 18th level, the range of this aura increases to 30 feet.",
    "mechanics": [
      {
        "type": "passive",
        "effects": [
          {
            "aura": {
              "radius": 10,
              "unit": "feet",
              "target": {
                "type": "creatures",
                "disposition": "any",
                "include_self": true
              },
              "grants": {
                "attribute": {
                  "target": "damage.melee_weapon.modifier",
                  "calculation": {
                    "operation": "add",
                    "operators": [
                      {
                        "type": "ability_modifier",
                        "ability": "Charisma"
                      }
                    ],
                    "bounds": { "minimum": 1 }
                  }
                }
              }
            }
          }
        ],
        "scaling": {
          "components": {
            "aura.radius": {
              "by_level": {
                "7": 10,
                "18": 30
              }
            }
          }
        }
      }
    ],
    "source": "dmg",
    "ruleset": "dnd5e"
  },
  {
