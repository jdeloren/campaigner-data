[
  {
    "id": "feat:oath-of-redemption-oath-spells",
    "class": "subclass:oath-of-redemption",
    "level": 3,
    "name": "Oath Spells",
    "description": "You gain oath spells at the paladin levels listed. Once you gain an oath spell, you always have it prepared, and it doesn't count against the number of spells you can prepare each day. If you have an oath spell that doesn't appear on the paladin spell list, the spell is nonetheless a paladin spell for you.",
    "mechanics": [
      {
        "type": "granted_spells",
        "always_prepared": true,
        "scaling": {
          "by_level": {
            "3": ["spell:sanctuary", "spell:sleep"],
            "5": ["spell:calm-emotions", "spell:hold-person"],
            "9": ["spell:counterspell", "spell:hypnotic-pattern"],
            "13": ["spell:otilukes-resilient-sphere", "spell:stoneskin"],
            "17": ["spell:hold-monster", "spell:wall-of-force"]
          }
        }
      }
    ],
    "source": "xge",
    "ruleset": "dnd5e"
  },
  {
